# ── Required ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars

# ── Supabase (shared DB) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Public URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://admin.tickgas.com

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://admin.tickgas.com

# ── Admin bootstrap (used before admins table is seeded) ─────────────────────
ADMIN_EMAIL=admin@tickgas.com
ADMIN_PASSWORD_HASH=bcrypt_hash_of_your_password

# ── Africa's Talking SMS ──────────────────────────────────────────────────────
AT_USERNAME=sandbox
AT_API_KEY=your_at_api_key
AT_SENDER_ID=TickGas
